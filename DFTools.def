# DFTools — the open-source EDA toolchain DFHDL depends on, as a single Apptainer image.
#
# Multi-stage build:
#   * stage `build`  — a heavy image with full toolchains; clones each tool at the
#                      revision pinned in pins.env and installs it into /opt/dftools.
#   * final stage    — a minimal runtime image that copies ONLY /opt/dftools from the
#                      build stage and installs just the runtime shared libraries.
#                      None of the compilers, source trees, or build artifacts from the
#                      build stage reach the published .sif.
#
# Build:  apptainer build dftools.sif DFTools.def        (real root: CI / Docker)
#         or via scripts/build.sc (Scalapptainer).
#
# Lines marked `# VALIDATE:` encode upstream build specifics that must be confirmed
# against the first real CI build and adjusted there if upstream has moved.

# =============================================================================
# Stage 1: build everything into /opt/dftools
# =============================================================================
Bootstrap: docker
From: ubuntu:24.04
Stage: build

%files
    pins.env /opt/pins.env
    build/strip-runtime.sh /opt/strip-runtime.sh

%post
    set -eux
    export DEBIAN_FRONTEND=noninteractive
    export PREFIX=/opt/dftools
    export PATH=$PREFIX/bin:$PATH
    mkdir -p $PREFIX /src
    . /opt/pins.env

    ARCH="$(uname -m)"                       # x86_64 | aarch64

    # ---- build-only toolchains & headers (NONE of this reaches the final image) ----
    apt-get update
    apt-get install -y --no-install-recommends \
        ca-certificates git curl xz-utils pkg-config \
        build-essential clang g++ gnat \
        cmake ninja-build autoconf automake libtool gperf help2man \
        flex bison \
        python3 python3-dev python3-venv python3-pip \
        llvm-dev libclang-dev \
        zlib1g-dev libzstd-dev libreadline-dev libffi-dev tcl-dev \
        libboost-all-dev libeigen3-dev \
        libftdi1-dev libhidapi-dev libudev-dev libusb-1.0-0-dev \
        libdw-dev check
    rm -rf /var/lib/apt/lists/*

    LLVM_CONFIG="$(command -v llvm-config || ls /usr/bin/llvm-config-* | sort -V | tail -1)"
    NPROC="$(nproc)"

    # A single shared Python venv for the tools that need a Python runtime
    # (apicula/gowin_pack, eqy). nextpnr only needs Python at build time.
    python3 -m venv $PREFIX/pyenv
    export PATH=$PREFIX/pyenv/bin:$PATH
    pip install --no-cache-dir --upgrade pip wheel

    clone() {  # clone <url> <rev> <dir> [--recursive]
        git clone ${4:-} "$1" "/src/$3"
        git -C "/src/$3" checkout --detach "$2"
        if [ "${4:-}" = "--recursive" ]; then git -C "/src/$3" submodule update --init --recursive; fi
    }

    # ----------------------------- Verilator -----------------------------------
    clone https://github.com/verilator/verilator "$VERILATOR_REV" verilator
    ( cd /src/verilator && autoconf && ./configure --prefix=$PREFIX \
        && make -j"$NPROC" && make install )

    # --------------------------- Icarus Verilog --------------------------------
    clone https://github.com/steveicarus/iverilog "$IVERILOG_REV" iverilog
    ( cd /src/iverilog && sh autoconf.sh && ./configure --prefix=$PREFIX \
        && make -j"$NPROC" && make install )

    # -------------------------------- GHDL -------------------------------------
    # LLVM backend works on both x86_64 and aarch64 (mcode is x86-only), so we use
    # one path for both arches.
    clone https://github.com/ghdl/ghdl "$GHDL_REV" ghdl
    ( cd /src/ghdl && ./configure --prefix=$PREFIX --with-llvm-config="$LLVM_CONFIG" \
        && make -j"$NPROC" && make install )

    # -------------------------------- NVC --------------------------------------
    clone https://github.com/nickg/nvc "$NVC_REV" nvc
    ( cd /src/nvc && ./autogen.sh && mkdir -p build && cd build \
        && ../configure --prefix=$PREFIX --with-llvm="$LLVM_CONFIG" \
        && make -j"$NPROC" && make install )

    # ------------------------------- Yosys -------------------------------------
    # --recursive pins the bundled ABC via Yosys's own submodule (no separate pin).
    clone https://github.com/YosysHQ/yosys "$YOSYS_REV" yosys --recursive
    ( cd /src/yosys && make config-gcc \
        && make -j"$NPROC" PREFIX=$PREFIX ENABLE_LIBYOSYS=1 \
        && make install PREFIX=$PREFIX )

    # ----------------------- GHDL-Yosys plugin (-m ghdl) -----------------------
    # Built against the Yosys + GHDL above; installs ghdl.so into Yosys's plugin dir
    # (under $PREFIX), loaded by DFHDL via `yosys -m ghdl`.
    # VALIDATE: plugin ABI must match YOSYS_REV; bump GHDL_YOSYS_PLUGIN_REV if it fails.
    clone https://github.com/ghdl/ghdl-yosys-plugin "$GHDL_YOSYS_PLUGIN_REV" ghdl-yosys-plugin
    ( cd /src/ghdl-yosys-plugin && make GHDL=$PREFIX/bin/ghdl && make install )

    # ----------------------------- Project Trellis -----------------------------
    # Provides ecppack and the ECP5 database consumed by nextpnr-ecp5.
    clone https://github.com/YosysHQ/prjtrellis "$PRJTRELLIS_REV" prjtrellis --recursive
    ( cd /src/prjtrellis/libtrellis \
        && cmake -DCMAKE_INSTALL_PREFIX=$PREFIX -G Ninja . \
        && ninja && ninja install )

    # -------------------------------- Apicula ----------------------------------
    # Python package providing gowin_pack and the Gowin chip DB (needed by
    # nextpnr-himbaechel at build time and gowin_pack at runtime).
    # VALIDATE: source install of the chip DB; the PyPI `apycula` ships prebuilt DBs
    # if a from-source DB build is problematic.
    clone https://github.com/YosysHQ/apicula "$APICULA_REV" apicula
    ( cd /src/apicula && pip install --no-cache-dir . )

    # ------------------------------- nextpnr -----------------------------------
    # One build with both arches: ECP5 (Lattice) and Himbaechel/Gowin.
    # Apicula must be importable for the Gowin chipdb generation step.
    clone https://github.com/YosysHQ/nextpnr "$NEXTPNR_REV" nextpnr --recursive
    ( cd /src/nextpnr \
        && cmake -B build -G Ninja \
            -DCMAKE_INSTALL_PREFIX=$PREFIX \
            -DARCH="ecp5;himbaechel" \
            -DHIMBAECHEL_UARCH=gowin \
            -DHIMBAECHEL_GOWIN_DEVICES=all \
            -DTRELLIS_INSTALL_PREFIX=$PREFIX \
            -DBUILD_GUI=OFF \
            -DCMAKE_BUILD_TYPE=Release \
        && ninja -C build && ninja -C build install )

    # ---------------------------- openFPGALoader --------------------------------
    clone https://github.com/trabucayre/openFPGALoader "$OPENFPGALOADER_REV" openFPGALoader
    ( cd /src/openFPGALoader \
        && cmake -B build -G Ninja -DCMAKE_INSTALL_PREFIX=$PREFIX -DCMAKE_BUILD_TYPE=Release \
        && ninja -C build && ninja -C build install )

    # -------------------------------- eqy --------------------------------------
    # Equivalence-checking driver around Yosys; Python + a small compiled helper.
    clone https://github.com/YosysHQ/eqy "$EQY_REV" eqy
    ( cd /src/eqy && make -j"$NPROC" PREFIX=$PREFIX && make install PREFIX=$PREFIX )

    # ------------------------------- Surfer ------------------------------------
    # Rust waveform viewer (GUI). Built with a throwaway rustup toolchain; only the
    # final `surfer` binary is installed into $PREFIX/bin.
    curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --profile minimal
    . "$HOME/.cargo/env"
    clone https://gitlab.com/surfer-project/surfer "$SURFER_REV" surfer --recursive
    ( cd /src/surfer && cargo build --release --locked -p surfer \
        && install -Dm755 target/release/surfer $PREFIX/bin/surfer )

    # record what we built, for the image manifest / provenance
    {
        echo "# DFTools build manifest"
        echo "arch=$ARCH"
        grep -E '_REV=' /opt/pins.env || true
    } > $PREFIX/MANIFEST.txt

    # Prune build-only artifacts and strip binaries here, while binutils is still
    # available, so the final stage copies an already-minimal prefix.
    sh /opt/strip-runtime.sh $PREFIX

# =============================================================================
# Stage 2: minimal runtime image — only /opt/dftools + runtime shared libs
# =============================================================================
Bootstrap: docker
From: ubuntu:24.04
Stage: final

%files from build
    /opt/dftools /opt/dftools

%post
    set -eux
    export DEBIAN_FRONTEND=noninteractive

    # Runtime shared libraries only — no -dev packages, no compilers. The prefix was
    # already pruned and stripped in the build stage.
    apt-get update
    apt-get install -y --no-install-recommends \
        ca-certificates \
        python3 \
        libstdc++6 libgcc-s1 \
        zlib1g libzstd1 libreadline8t64 libffi8 libtcl8.6 \
        libboost-filesystem1.83.0 libboost-program-options1.83.0 \
        libboost-thread1.83.0 libboost-iostreams1.83.0 \
        libftdi1-2 libhidapi-hidraw0 libusb-1.0-0 libudev1 \
        libdw1 \
        libllvm18 \
        libgl1 libx11-6 libxext6 libxrender1 libxkbcommon0 libwayland-client0
    rm -rf /var/lib/apt/lists/*

%environment
    export PATH=/opt/dftools/bin:/opt/dftools/pyenv/bin:$PATH
    export LD_LIBRARY_PATH=/opt/dftools/lib:/opt/dftools/lib64:$LD_LIBRARY_PATH

%labels
    org.opencontainers.image.title DFTools
    org.opencontainers.image.description Open-source EDA toolchain for DFHDL
    org.opencontainers.image.source https://github.com/DFiantHDL/DFTools
    org.opencontainers.image.licenses Apache-2.0

%runscript
    exec "$@"

%test
    set -e
    export PATH=/opt/dftools/bin:/opt/dftools/pyenv/bin:$PATH
    verilator --version
    iverilog -V 2>&1 | head -1
    ghdl version | head -1
    nvc --version
    yosys -V
    yosys -m ghdl -p 'help ghdl' >/dev/null
    nextpnr-ecp5 --version
    nextpnr-himbaechel --version
    ecppack --help >/dev/null 2>&1 || true
    gowin_pack --help >/dev/null 2>&1 || true
    openFPGALoader --Version || openFPGALoader -V
    eqy --version || true
    surfer --version || true
