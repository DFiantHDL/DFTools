# DFTools image: pnr
# Place & route + bitstream packing for ECP5 (Lattice) and Himbaechel/Gowin.
# Consumes Yosys netlist JSON (produced by the synth-* images) over the mounted workdir.

Bootstrap: docker
From: ubuntu:24.04
Stage: build

%files
    pins.env /opt/pins.env
    build/common.sh /opt/common.sh
    build/strip-runtime.sh /opt/strip-runtime.sh

%post
    set -eux
    export DEBIAN_FRONTEND=noninteractive
    export PREFIX=/opt/dftools
    . /opt/pins.env
    apt-get update
    apt-get install -y --no-install-recommends \
        ca-certificates git pkg-config \
        build-essential cmake ninja-build \
        libboost-all-dev libeigen3-dev zlib1g-dev \
        python3 python3-dev python3-venv python3-pip
    rm -rf /var/lib/apt/lists/*
    . /opt/common.sh
    py_venv

    # Project Trellis -> ecppack + ECP5 database
    clone https://github.com/YosysHQ/prjtrellis "$PRJTRELLIS_REV" prjtrellis --recursive
    ( cd /src/prjtrellis/libtrellis \
        && cmake -DCMAKE_INSTALL_PREFIX=$PREFIX -G Ninja . \
        && ninja && ninja install )

    # Apicula -> gowin_pack + Gowin chip DB (Python). VALIDATE: from-source DB build;
    # the PyPI `apycula` ships prebuilt DBs if a source DB build is problematic.
    clone https://github.com/YosysHQ/apicula "$APICULA_REV" apicula
    ( cd /src/apicula && pip install --no-cache-dir . )

    # nextpnr: one build with both arches (ECP5 + Himbaechel/Gowin).
    clone https://github.com/YosysHQ/nextpnr "$NEXTPNR_REV" nextpnr --recursive
    ( cd /src/nextpnr \
        && cmake -B build -G Ninja \
            -DCMAKE_INSTALL_PREFIX=$PREFIX \
            -DARCH="ecp5;himbaechel" \
            -DHIMBAECHEL_UARCH=gowin \
            -DHIMBAECHEL_GOWIN_DEVICES=all \
            -DTRELLIS_INSTALL_PREFIX=$PREFIX \
            -DBUILD_GUI=OFF -DCMAKE_BUILD_TYPE=Release \
        && ninja -C build && ninja -C build install )

    write_manifest pnr
    sh /opt/strip-runtime.sh $PREFIX

Bootstrap: docker
From: ubuntu:24.04
Stage: final

%files from build
    /opt/dftools /opt/dftools

%post
    set -eux
    export DEBIAN_FRONTEND=noninteractive
    apt-get update
    apt-get install -y --no-install-recommends \
        ca-certificates python3 \
        libstdc++6 libgcc-s1 zlib1g \
        libboost-filesystem1.83.0 libboost-program-options1.83.0 \
        libboost-thread1.83.0 libboost-iostreams1.83.0
    rm -rf /var/lib/apt/lists/*

%environment
    export PATH=/opt/dftools/bin:/opt/dftools/pyenv/bin:$PATH
    export LD_LIBRARY_PATH=/opt/dftools/lib:/opt/dftools/lib64:$LD_LIBRARY_PATH

%labels
    org.opencontainers.image.title DFTools/pnr
    org.opencontainers.image.source https://github.com/DFiantHDL/DFTools
    org.opencontainers.image.licenses Apache-2.0

%runscript
    exec "$@"

%test
    set -e
    export PATH=/opt/dftools/bin:/opt/dftools/pyenv/bin:$PATH
    nextpnr-ecp5 --version
    nextpnr-himbaechel --version
    ecppack --help >/dev/null 2>&1 || true
    gowin_pack --help >/dev/null 2>&1 || true
