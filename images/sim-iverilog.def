# DFTools image: sim-iverilog
# Icarus Verilog simulation (iverilog compiler + vvp runtime engine). Small, self-contained.

Bootstrap: docker
From: ubuntu:24.04
Stage: build

%files
    pins.env /opt/pins.env
    build/common.sh /opt/common.sh
    build/strip-runtime.sh /opt/strip-runtime.sh

%post
    set -eux
    export DEBIAN_FRONTEND=noninteractive
    export PREFIX=/opt/dftools
    . /opt/pins.env
    apt-get update
    apt-get install -y --no-install-recommends \
        ca-certificates git pkg-config \
        build-essential autoconf gperf flex bison zlib1g-dev
    rm -rf /var/lib/apt/lists/*
    . /opt/common.sh

    clone https://github.com/steveicarus/iverilog "$IVERILOG_REV" iverilog
    ( cd /src/iverilog && sh autoconf.sh && ./configure --prefix=$PREFIX \
        && make -j"$NPROC" && make install )

    write_manifest sim-iverilog
    sh /opt/strip-runtime.sh $PREFIX

Bootstrap: docker
From: ubuntu:24.04
Stage: final

%files from build
    /opt/dftools /opt/dftools

%post
    set -eux
    export DEBIAN_FRONTEND=noninteractive
    apt-get update
    apt-get install -y --no-install-recommends \
        ca-certificates \
        libstdc++6 libgcc-s1 zlib1g libbz2-1.0
    rm -rf /var/lib/apt/lists/*

%environment
    export PATH=/opt/dftools/bin:$PATH
    export LD_LIBRARY_PATH=/opt/dftools/lib:/opt/dftools/lib64:$LD_LIBRARY_PATH

%labels
    org.opencontainers.image.title DFTools/sim-iverilog
    org.opencontainers.image.source https://github.com/DFiantHDL/DFTools
    org.opencontainers.image.licenses Apache-2.0

%runscript
    exec "$@"

%test
    set -e
    export PATH=/opt/dftools/bin:$PATH
    iverilog -V 2>&1 | head -1
    vvp -V 2>&1 | head -1
