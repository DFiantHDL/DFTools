# DFTools image: synth-vhdl
# Yosys VHDL synthesis via the GHDL frontend plugin (`yosys -m ghdl`).
# The ghdl here is the synthesis frontend (plugin-ABI-bound to YOSYS_REV) and carries
# LLVM; it is pinned independently (GHDL_SYNTH_REV) from the simulator ghdl in sim-llvm.

Bootstrap: docker
From: ubuntu:24.04
Stage: build

%files
    pins.env /opt/pins.env
    build/common.sh /opt/common.sh
    build/strip-runtime.sh /opt/strip-runtime.sh

%post
    set -eux
    export DEBIAN_FRONTEND=noninteractive
    export PREFIX=/opt/dftools
    . /opt/pins.env
    apt-get update
    apt-get install -y --no-install-recommends \
        ca-certificates git pkg-config \
        build-essential clang cmake ninja-build bison flex libfl-dev \
        gnat llvm-dev libclang-dev \
        libreadline-dev tcl-dev libffi-dev zlib1g-dev \
        python3 python3-dev python3-venv python3-pip
    rm -rf /var/lib/apt/lists/*
    . /opt/common.sh
    LLVM_CONFIG="$(llvm_config)"

    # GHDL (synthesis frontend) — LLVM backend (works on x86_64 and aarch64)
    clone https://github.com/ghdl/ghdl "$GHDL_SYNTH_REV" ghdl
    ( cd /src/ghdl && ./configure --prefix=$PREFIX --with-llvm-config="$LLVM_CONFIG" \
        && make -j"$NPROC" && make install )

    # Yosys
    clone https://github.com/YosysHQ/yosys "$YOSYS_REV" yosys --recursive
    ( cd /src/yosys && make config-gcc \
        && make -j"$NPROC" PREFIX=$PREFIX ENABLE_LIBYOSYS=1 \
        && make install PREFIX=$PREFIX )

    # GHDL-Yosys plugin -> installs ghdl.so into Yosys's plugin dir (under $PREFIX).
    # VALIDATE: plugin ABI must match YOSYS_REV; bump GHDL_YOSYS_PLUGIN_REV if it fails.
    clone https://github.com/ghdl/ghdl-yosys-plugin "$GHDL_YOSYS_PLUGIN_REV" ghdl-yosys-plugin
    ( cd /src/ghdl-yosys-plugin && make GHDL=$PREFIX/bin/ghdl && make install )

    write_manifest synth-vhdl
    sh /opt/strip-runtime.sh $PREFIX

Bootstrap: docker
From: ubuntu:24.04
Stage: final

%files from build
    /opt/dftools /opt/dftools

%post
    set -eux
    export DEBIAN_FRONTEND=noninteractive
    apt-get update
    apt-get install -y --no-install-recommends \
        ca-certificates python3 \
        libstdc++6 libgcc-s1 libgnat-13 zlib1g libreadline8t64 libffi8 libtcl8.6 libllvm18
    rm -rf /var/lib/apt/lists/*

%environment
    export PATH=/opt/dftools/bin:/opt/dftools/pyenv/bin:$PATH
    export LD_LIBRARY_PATH=/opt/dftools/lib:/opt/dftools/lib64:$LD_LIBRARY_PATH

%labels
    org.opencontainers.image.title DFTools/synth-vhdl
    org.opencontainers.image.source https://github.com/DFiantHDL/DFTools
    org.opencontainers.image.licenses Apache-2.0

%runscript
    exec "$@"

%test
    set -e
    export PATH=/opt/dftools/bin:$PATH
    ghdl version | head -1
    yosys -V
    yosys -m ghdl -p 'help ghdl' >/dev/null
