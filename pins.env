# DFTools source pins — the single source of truth for reproducible builds.
#
# Each tool is built from source at the exact revision below. A revision may be a
# tag (preferred, when the upstream cuts releases) or a full/short commit SHA
# (for tools that do not tag releases). Bumping a tool = editing one line here;
# that diff is what triggers the build -> test -> publish cycle in CI.
#
# Format: <NAME>_REV=<git-ref>   (tag name, branch is NOT allowed — must be
# reproducible; use a SHA to pin a moving branch). Clone URLs live in DFTools.def.
#
# After the FIRST green CI build, replace every commit-pinned `*_REV` that points
# at a branch head with the exact SHA that built, so the image is fully reproducible.

# --- Simulators ---
VERILATOR_REV=v5.048
IVERILOG_REV=v13_0
GHDL_REV=v6.0.0
NVC_REV=r1.21.1

# --- Synthesis (Yosys + the GHDL VHDL frontend plugin) ---
# Yosys is cloned --recursive so its bundled ABC is pinned by Yosys's own submodule
# (no separate ABC pin needed). The GHDL plugin must be ABI-compatible with the
# Yosys above and is built against it; lock to a SHA after first green build.
YOSYS_REV=v0.66
GHDL_YOSYS_PLUGIN_REV=0afb85a32fbd

# --- Place & route + bitstream (ECP5 / Lattice and Himbaechel / Gowin) ---
NEXTPNR_REV=nextpnr-0.10
PRJTRELLIS_REV=1.4
APICULA_REV=0.32

# --- Programmer ---
OPENFPGALOADER_REV=v1.1.1

# --- Formal equivalence utility ---
EQY_REV=8770b67d0bc8

# --- Waveform viewer (GUI; needs X11) ---
SURFER_REV=v0.7.0
