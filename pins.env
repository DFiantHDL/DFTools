# DFTools source pins — the single source of truth for reproducible builds.
#
# Each tool is built from source at the exact revision below. A revision may be a
# tag (preferred, when the upstream cuts releases) or a full/short commit SHA
# (for tools that do not tag releases). Bumping a tool = editing one line here;
# the diff triggers a rebuild + retest of only the image(s) that contain it.
#
# Format: <NAME>_REV=<git-ref>   (tag name, or a SHA to pin a moving branch —
# never a bare branch name). Clone URLs live in build/common.sh.
#
# After the FIRST green CI build, harden every commit-pinned `*_REV` that points
# at a branch head to the exact SHA that built, for full reproducibility.

# === image: synth-verilog  (yosys Verilog/SV synthesis + eqy) ===
YOSYS_REV=v0.66
YOSYS_SLANG_REV=009058e4c261          # SystemVerilog frontend plugin (povik/yosys-slang master)
EQY_REV=8770b67d0bc8

# === image: synth-vhdl  (yosys + GHDL VHDL frontend) ===
# Yosys is cloned --recursive so its bundled ABC is pinned by Yosys's submodule.
# GHDL here is the *synthesis frontend* ghdl. ghdl-yosys-plugin tracks ghdl master
# (it uses libghdl synth APIs like get_sname_index not present in the v6.0.0 release),
# so this is pinned to a ghdl master commit matching the plugin — independently from
# the stable simulator ghdl below.
GHDL_SYNTH_REV=2bb1a77248b9
GHDL_YOSYS_PLUGIN_REV=0afb85a32fbd

# === image: pnr  (place & route + bitstream for ECP5 / Gowin) ===
NEXTPNR_REV=nextpnr-0.10
PRJTRELLIS_REV=1.4
APICULA_REV=0.32

# === image: sim-llvm  (LLVM-based VHDL simulators: nvc + ghdl) ===
# The *simulator* ghdl, pinned independently from the synthesis-frontend ghdl above.
NVC_REV=r1.21.1
GHDL_SIM_REV=v6.0.0

# === image: sim-verilator  (Verilog/SV simulation; carries a C++ build env) ===
VERILATOR_REV=v5.048

# === image: sim-iverilog  (Icarus Verilog simulation) ===
IVERILOG_REV=v13_0

# === image: wavegen  (waveform viewer; GUI / X11) ===
SURFER_REV=v0.7.0

# === image: program  (FPGA programmer) ===
OPENFPGALOADER_REV=v1.1.1
